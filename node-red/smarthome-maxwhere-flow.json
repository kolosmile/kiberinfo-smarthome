  {
    "id": "smarthome_normalize",
    "type": "function",
    "z": "3e20993d.c684a6",
    "name": "Normalize smart home command",
    "func": "const payload = msg.payload;\nconst rejected = (reason, raw) => {\n    const out = Array(11).fill(null);\n    out[10] = { payload: { accepted: false, reason, raw } };\n    node.status({ fill: 'yellow', shape: 'ring', text: reason });\n    return out;\n};\n\nif (!payload || typeof payload !== 'object' || Array.isArray(payload)) {\n    return rejected('payload is not an object', payload);\n}\n\nconst lampIndex = {\n    lamp_1: 1,\n    lamp_2: 2,\n    lamp_3: 3,\n    lamp_4: 4,\n};\n\nif (!(payload.device in lampIndex) && payload.device !== 'fan_1') {\n    return rejected(`ignored unsupported device: ${payload.device}`, payload);\n}\n\nif (payload.state !== 'on' && payload.state !== 'off') {\n    return rejected(`invalid state: ${payload.state}`, payload);\n}\n\nconst command = {\n    device: payload.device,\n    enabled: payload.state === 'on',\n};\n\nif (payload.device === 'fan_1') {\n    if (!Number.isInteger(payload.speed) || payload.speed < 0 || payload.speed > 100) {\n        return rejected(`invalid fan speed: ${payload.speed}`, payload);\n    }\n    command.type = 'fan';\n    command.target = 'Fan_1';\n    command.speed = payload.speed;\n} else {\n    command.type = 'lamp';\n    command.target = `Lamp_${lampIndex[payload.device]}`;\n}\n\nmsg.payload = command;\nmsg.topic = `${command.device}:${command.enabled ? 'on' : 'off'}`;\nnode.status({ fill: 'green', shape: 'dot', text: msg.topic });\n\nconst out = Array(11).fill(null);\nif (command.type === 'lamp') {\n    const base = (lampIndex[command.device] - 1) * 2;\n    out[base + (command.enabled ? 0 : 1)] = msg;\n} else {\n    out[8] = msg;\n}\nout[9] = { payload: command };\nreturn out;",
    "outputs": 11,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1680,
    "y": 860,
    "wires": [
