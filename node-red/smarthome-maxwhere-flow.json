  {
    "id": "smarthome_fan_animator",
    "type": "function",
    "z": "3e20993d.c684a6",
    "name": "Fan speed to rotation",
    "func": "const command = msg.payload;\nlet timer = context.get('timer');\nif (timer) {\n    clearInterval(timer);\n    context.set('timer', null);\n}\n\nlet angle = context.get('angle') || 0;\n\nfunction sendOrientation(currentAngle) {\n    const half = currentAngle / 2;\n    node.send({\n        payload: {\n            subject: 'Fan_1',\n            data: {\n                msg: 'fan axial rotation',\n                value: {\n                    x: 0,\n                    y: 0,\n                    z: Math.sin(half),\n                    w: Math.cos(half),\n                },\n            },\n        },\n    });\n}\n\nif (!command.enabled || command.speed <= 0) {\n    context.set('angle', angle);\n    node.status({ fill: 'grey', shape: 'ring', text: 'fan off' });\n    sendOrientation(angle);\n    return null;\n}\n\n// Keep the visual range low enough to avoid aliasing/reverse-spin illusion.\n// At 25 Hz this maps 1..100% roughly to 0.28..1.5 rad/s.\nconst step = 0.01 + (command.speed / 100) * 0.05;\ntimer = setInterval(() => {\n    angle = (angle + step) % (Math.PI * 2);\n    context.set('angle', angle);\n    sendOrientation(angle);\n}, 40);\n\ncontext.set('timer', timer);\nnode.status({ fill: 'blue', shape: 'dot', text: `fan ${command.speed}%` });\nreturn null;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "const timer = context.get('timer');\nif (timer) clearInterval(timer);",
    "libs": [],
    "x": 1980,
    "y": 780,
    "wires": [
