{
  "name": "kiberinfo-smarthome",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; electron-builder --win",
    "dist:portable": "npm run build; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; electron-builder --win portable",
    "dist:installer": "npm run build; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; electron-builder --win nsis",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "mqtt": "^5.10.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "hu.bme.kiberinfo.smarthome",
    "productName": "Okosotthon Vezerlopult",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Okosotthon-Vezerlopult-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Okosotthon-Vezerlopult-${version}.exe"
    }
  }
}
